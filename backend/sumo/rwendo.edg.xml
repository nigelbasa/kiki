<!--
  Rwendo SUMO edges. One lane per direction on every corridor, 13.9 m/s
  speed limit (~50 km/h). Naming: FROM__TO. Incoming edges end at the
  junction; outgoing start at it.
-->
<edges>
    <!-- TL_00 north arm -->
    <edge id="EXT_TL00_N__TL_00" from="EXT_TL00_N" to="TL_00" numLanes="1" speed="13.9"/>
    <edge id="TL_00__EXT_TL00_N" from="TL_00" to="EXT_TL00_N" numLanes="1" speed="13.9"/>

    <!-- TL_00 west arm -->
    <edge id="EXT_TL00_W__TL_00" from="EXT_TL00_W" to="TL_00" numLanes="1" speed="13.9"/>
