    <!-- TL_00 <-> TL_11 internal link (Samora Machel diagonal via straight edge) -->
    <edge id="TL_00__TL_11" from="TL_00" to="TL_11" numLanes="1" speed="13.9"/>
    <edge id="TL_11__TL_00" from="TL_11" to="TL_00" numLanes="1" speed="13.9"/>

